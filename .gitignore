# Node / TypeScript
node_modules/
dist/
*.tsbuildinfo
.npm/
.yarn/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
probe-debug.log

# Environment
.env
.env.local
.env.*.local

# Anthropic keys — never commit
ANTHROPIC_API_KEY*

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Coverage / test
coverage/
.nyc_output/

# Failed/killed run artifacts — kept locally for post-hoc debugging, not
# tracked (contains embedded worktrees and redundant pipeline state).
logs/failed_run_artifacts/

# Probe-specific — runs are tracked, but working state and markers are not
runs/*/branches/*/DONE.marker
runs/*/branches/*/FAILED.marker
runs/*/branches/*/IN_PROGRESS.marker

# Build/run logs — ephemeral, never commit
logs/
*.log
*.log.attempt*

# Branch worktrees are checked-out copies of the main repo. They live as
# real `git worktree add` directories, so the parent repo should NEVER
# track them — not as files, not as gitlinks (submodule pointers). The
# trailing slash on the directory rule below is the load-bearing bit:
# without it, `git add` on a worktree directory captures it as a 160000
# mode submodule pointer, and GitHub Desktop then nags about "submodule
# changes" every time the worktree's HEAD advances.
runs/*/branches/*/
runs/*/branches/*/*

# Worktree metadata — worktree dirs themselves are inside runs/ and ARE tracked,
# but each worktree's .git file would double-track. Worktrees are created at runtime.
# The demo_run/ directory is tracked as snapshotted output.

# Cached API responses (local dev)
.cache/
tmp/

# Build artifacts
build/

# Demo recordings (large files — uploaded to YouTube/Loom)
demo/recorded_run/*.mp4
demo/recorded_run/*.mov
demo/recorded_run/*.webm
node_modules/
.claude/
docs/DEMO_SLIDES.md
PROJECT_FOR_LLM_EVAL.md
PROBE_SUGGESTED_FIXES_FOR_AGENT.md
UX_AUDIT_FINDINGS.md
docs/screenshots/audit/
SYSTEM_EXPLANATION.md
V3_BACKLOG.md
