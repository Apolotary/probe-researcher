# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model IDs
# PROBE_OPUS_MODEL=claude-opus-4-7
# PROBE_SONNET_MODEL=claude-sonnet-4-6

# Optional: budget enforcement — abort new runs if cumulative USD spend exceeds this
# PROBE_BUDGET_USD_LIMIT=500

# Optional: verbose stage-level logging to runs/<id>/debug.log
# PROBE_DEBUG=true
