{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "probe/imported_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "schema_version",
    "run_id",
    "source_file",
    "source_format",
    "sections",
    "inferred_premise_text",
    "inferred_method_summary",
    "provenance"
  ],
  "properties": {
    "stage": { "const": "0_import" },
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "pattern": "^[a-z0-9_-]{3,64}$" },
    "source_file": { "type": "string", "minLength": 1 },
    "source_format": { "enum": ["markdown", "latex", "text"] },
    "source_word_count": { "type": "integer", "minimum": 1 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "bucket", "heading", "content", "start_line", "end_line"],
        "properties": {
          "id": { "type": "string", "pattern": "^sec_[a-z0-9_]{1,32}$" },
          "bucket": {
            "enum": [
              "premise",
              "related_work",
              "prototype",
              "method",
              "rehearsal",
              "findings",
              "discussion",
              "limitations",
              "other"
            ]
          },
          "heading": { "type": "string", "minLength": 1, "maxLength": 300 },
          "content": { "type": "string", "minLength": 1 },
          "start_line": { "type": "integer", "minimum": 1 },
          "end_line": { "type": "integer", "minimum": 1 },
          "rationale": { "type": "string", "maxLength": 500 },
          "confidence": {
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "inferred_premise_text": {
      "type": "string",
      "minLength": 10,
      "maxLength": 600,
      "description": "One-sentence summary of the research question, extracted from the paper. Feeds Stage 6 audit as if it came from Stage 1."
    },
    "inferred_method_summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Terse structured summary of the study method that the audit can treat as a Stage 4 prototype spec equivalent."
    },
    "contains_real_user_data": {
      "type": "boolean",
      "description": "True if the paper contains real user-study data / participant quotes / pilot observations. The audit must not treat these as rehearsal."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classifier_model", "classifier_run_at"],
      "properties": {
        "classifier_model": { "type": "string" },
        "classifier_run_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
