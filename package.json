{
  "name": "probe-researcher",
  "version": "0.1.0",
  "description": "Probe — a research-design triage tool for screen-based interactive research.",
  "author": "Bektur Ryskeldiev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Apolotary/probe-researcher.git"
  },
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "probe": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && node -e \"console.log('typecheck passed; run \\`npx probe lint <file>\\` for provenance + voice lint on shipped guidebooks')\"",
    "typecheck": "tsc --noEmit",
    "probe": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "openai": "^6.34.0",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "files": [
    "dist/",
    "agents/",
    "corpus/",
    "patterns/",
    "schemas/",
    "README.md",
    "CLAUDE.md",
    "LICENSE",
    "NOTICE"
  ]
}
